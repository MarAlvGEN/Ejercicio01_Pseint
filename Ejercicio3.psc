Algoritmo Ejercicio3
	
	Definir num Como Entero
	
	Escribir "Coloca un numero"
	Leer num
	
	Si num >= 20
		Si num = 20
			Escribir "El numero ", num, " es igual a 20"
		SiNo
			EScribir "El numero ", num, " es mayor a 20"
		FinSi
	FinSi
	
	si num >= 10 Y num < 20
		si num = 10
			Escribir "El numero ", num," es igual a 10"
		SiNo
			Escribir "El numero ", num, " ss mayor a 10 y menor a 20"
		FinSi
	FinSi
	
	si num < 10
		Escribir "El numero ", num, " es menor a 10"
	FinSi
	
FinAlgoritmo